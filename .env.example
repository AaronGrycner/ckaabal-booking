# Google Cloud API key with Places API (New) enabled
GOOGLE_PLACES_API_KEY=

# Optional — falls back to GOOGLE_PLACES_API_KEY
PAGESPEED_API_KEY=

# Set to true to force sample data without API keys
MOCK_MODE=false

# Optional — local SQLite file (default for dev when Turso is not set)
DATABASE_URL=file:./data/booking-crm.db

# Turso (production / shared remote DB)
# 1. Install CLI: curl -sSfL https://get.tur.so/install.sh | bash
# 2. Login: turso auth login
# 3. Run: npm run db:setup-turso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# OpenAI — booking pitch email generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_DEFAULT_OUTREACH_MODEL=gpt-5.4-mini
OPENAI_PREMIUM_REVIEW_MODEL=gpt-5.5
OPENAI_ALWAYS_USE_FINAL_REVIEW=false
OPENAI_ENABLE_PREMIUM_POLISH=true
OPENAI_MAX_REWRITE_ATTEMPTS=1
OPENAI_OUTREACH_MAX_OUTPUT_TOKENS=500

# Gmail SMTP (App Password — requires 2FA on the Google account)
# GMAIL_USER = Google account that authenticates SMTP (your main login)
# GMAIL_FROM = optional alias recipients see (must be added under Gmail → Send mail as)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM=
GMAIL_FROM_NAME=

# Band / sender identity
OUTREACH_BAND_NAME=ckaabal
OUTREACH_BAND_GENRE=
OUTREACH_SENDER_NAME=ckaabal
OUTREACH_SENDER_TITLE=
OUTREACH_COMPANY_NAME=ckaabal
OUTREACH_TAGLINE=
OUTREACH_WEBSITE=ckaabal.com
OUTREACH_EMAIL=booking@ckaabal.com
OUTREACH_EPK_URL=https://drive.google.com/file/d/1IRY8dWYBz4xFwmZEPRFH3zmdNOnQfHez/view?usp=sharing

OUTREACH_SEND_COOLDOWN_MINUTES=2
OUTREACH_DEFAULT_FOLLOW_UP_DAYS=3

PUBLIC_SITE_URL=https://ckaabal.com

# CRM app public URL — tracked links hit THIS domain (/r/{token})
OUTREACH_TRACKING_BASE_URL=http://localhost:3000
OUTREACH_TRACKING_HOST=

# Where /r/{token} redirects after logging the click (EPK or band site)
OUTREACH_DEFAULT_TRACKED_DESTINATION=https://drive.google.com/file/d/1IRY8dWYBz4xFwmZEPRFH3zmdNOnQfHez/view?usp=sharing

OUTREACH_CLICK_IP_HASH_SALT=
